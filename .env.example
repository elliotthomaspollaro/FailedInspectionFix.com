# ─── FailedInspectionFix.com Environment Variables ───

# Database (PostgreSQL / Supabase)
DATABASE_URL="postgresql://postgres:password@localhost:5432/failedinspection?schema=public"

# ─── API Switchboard: Multi-Network Lead Routing ───

# Radon Mitigation → ServiceDirect
SERVICE_DIRECT_API_URL="https://api.servicedirect.com/v1/leads"
SERVICE_DIRECT_API_KEY="your-service-direct-key"

# Oil Tank & Asbestos/Lead → PX Marketplace
PX_MARKETPLACE_API_URL="https://api.px.com/v1/leads"
PX_MARKETPLACE_API_KEY="your-px-marketplace-key"

# Sewer Scope Repair → Networx
NETWORX_API_URL="https://api.networx.com/v1/leads"
NETWORX_API_KEY="your-networx-key"

# ─── Alerting (Unsold Lead Safety Net) ───
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/your-webhook-url"

# ─── App Config ───
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Analytics (GA4)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
